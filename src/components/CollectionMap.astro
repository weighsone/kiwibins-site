---
import schedule from '../data/schedule.json';
const { areas, globalNote } = schedule;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!-- Leaflet CSS -->
<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
  crossorigin="anonymous"
/>

<div class="space-y-6">

  <!-- Address lookup -->
  <div class="card">
    <label class="form-label text-base" for="address-input">Find your collection area</label>
    <p class="text-sm text-gray-500 mb-3">Type your street address to find out which zone you're in and when we collect.</p>
    <div class="flex gap-2">
      <input
        type="text"
        id="address-input"
        class="form-input flex-1"
        placeholder="e.g. 42 Queen Street, Levin"
        autocomplete="off"
        aria-label="Street address"
      />
      <button id="address-search" type="button" class="btn-primary shrink-0 px-5">
        Find
      </button>
    </div>
    <div id="address-result" class="mt-3 hidden text-sm" role="alert" aria-live="polite"></div>
  </div>

  <!-- Or pick from dropdown -->
  <div class="card">
    <label for="area-select" class="form-label text-base">
      Or select your suburb
    </label>
    <div class="flex flex-col sm:flex-row gap-3 mt-1">
      <select id="area-select" class="form-select flex-1" aria-label="Select your suburb or area">
        <option value="">— Select your suburb or area —</option>
        {areas.map((area) => (
          <option value={area.id}>{area.name}</option>
        ))}
      </select>
    </div>
  </div>

  <!-- Result card (hidden until area selected) -->
  <div id="schedule-result" class="card hidden animate-slide-up" aria-live="polite" aria-atomic="true">
    <div class="flex items-start gap-4">
      <div id="result-icon" class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0 text-white" aria-hidden="true">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/>
        </svg>
      </div>
      <div class="flex-1 min-w-0">
        <h3 id="result-area" class="font-bold text-kiwi-900 text-lg"></h3>
        <div class="mt-2 space-y-1.5">
          <div class="flex items-center gap-2 text-sm text-gray-700">
            <svg class="w-4 h-4 text-kiwi-600 shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/>
            </svg>
            <span><strong>Collection day:</strong> <span id="result-day"></span></span>
          </div>
          <div class="flex items-center gap-2 text-sm text-gray-700">
            <svg class="w-4 h-4 text-kiwi-600 shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
            </svg>
            <span><strong>Frequency:</strong> <span id="result-freq"></span></span>
          </div>
          <p id="result-notes" class="text-sm text-gray-500 mt-2 italic"></p>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile map toggle -->
  <div class="sm:hidden">
    <button
      id="map-toggle"
      type="button"
      class="btn-secondary w-full text-sm"
      aria-expanded="false"
      aria-controls="map-wrapper"
    >
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
        <path fill-rule="evenodd" d="M12 1.586l-4 4v12.828l4-4V1.586zM3.707 3.293A1 1 0 002 4v10a1 1 0 00.293.707L6 18.414V5.586L3.707 3.293zM17.707 5.293L14 1.586v12.828l2.293 2.293A1 1 0 0018 16V6a1 1 0 00-.293-.707z" clip-rule="evenodd"/>
      </svg>
      View Service Area Map
    </button>
  </div>

  <!-- Map container -->
  <div id="map-wrapper" class="hidden sm:block">
    <div class="rounded-2xl overflow-hidden border border-gray-200 shadow-sm">
      <div
        id="collection-map"
        style="height: 480px; width: 100%;"
        role="application"
        aria-label="Interactive map showing Kiwibins service areas across Horowhenua"
      ></div>
    </div>
    <p class="text-xs text-gray-400 mt-2 flex items-center gap-1">
      <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
      </svg>
      Map boundaries are indicative only. Contact us to confirm your collection day.
    </p>
  </div>

  <!-- Schedule table -->
  <div class="card overflow-x-auto">
    <h3 class="text-base font-bold text-kiwi-900 mb-4">Full Collection Schedule</h3>
    <table class="w-full text-sm" role="table">
      <thead>
        <tr class="text-left border-b border-gray-200">
          <th class="pb-3 pr-4 font-semibold text-gray-600" scope="col">Area</th>
          <th class="pb-3 pr-4 font-semibold text-gray-600" scope="col">Day</th>
          <th class="pb-3 font-semibold text-gray-600" scope="col">Frequency</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        {areas.map((area) => (
          <tr class="hover:bg-gray-50 transition-colors">
            <td class="py-3 pr-4 text-gray-900 font-medium">
              <span
                class="inline-block w-2.5 h-2.5 rounded-full mr-2 align-middle"
                style={`background-color: ${area.color}`}
                aria-hidden="true"
              ></span>
              {area.name}
            </td>
            <td class="py-3 pr-4 text-gray-700">{area.day}</td>
            <td class="py-3">
              <span
                class:list={[
                  'inline-block text-xs font-medium px-2 py-0.5 rounded-full',
                  area.frequency === 'Weekly'
                    ? 'bg-kiwi-100 text-kiwi-700'
                    : 'bg-amber-100 text-amber-700',
                ]}
              >
                {area.frequency}
              </span>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
    <p class="text-xs text-gray-500 mt-4 border-t border-gray-100 pt-3">{globalNote}</p>
  </div>

</div>

<script define:vars={{ areas, base }}>
  // ── Haversine distance (km) ──────────────────────────────────────────────
  function haversine(lat1, lng1, lat2, lng2) {
    const R = 6371;
    const dLat = (lat2 - lat1) * Math.PI / 180;
    const dLng = (lng2 - lng1) * Math.PI / 180;
    const a = Math.sin(dLat / 2) ** 2
      + Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) * Math.sin(dLng / 2) ** 2;
    return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
  }

  function findNearestArea(lat, lng) {
    let nearest = null;
    let minDist = Infinity;
    for (const area of areas) {
      const d = haversine(lat, lng, area.lat, area.lng);
      if (d < minDist) { minDist = d; nearest = area; }
    }
    return { area: nearest, distance: minDist };
  }

  // ── Show result card ─────────────────────────────────────────────────────
  const areaData = Object.fromEntries(areas.map((a) => [a.id, a]));

  function showAreaResult(area) {
    document.getElementById('result-area').textContent = area.name;
    document.getElementById('result-day').textContent = area.day;
    document.getElementById('result-freq').textContent = area.frequency;
    document.getElementById('result-notes').textContent = area.notes;
    document.getElementById('result-icon').style.backgroundColor = area.color;
    document.getElementById('schedule-result').classList.remove('hidden');

    if (window._leafletMap && window._leafletMarkers && window._leafletMarkers[area.id]) {
      window._leafletMap.flyTo(window._leafletMarkers[area.id].getLatLng(), 13, { duration: 0.8 });
      window._leafletMarkers[area.id].openPopup();
    }
  }

  // ── Dropdown ─────────────────────────────────────────────────────────────
  document.getElementById('area-select')?.addEventListener('change', (e) => {
    const id = e.target.value;
    const result = document.getElementById('schedule-result');
    if (!id) { result?.classList.add('hidden'); return; }
    const area = areaData[id];
    if (area) showAreaResult(area);
  });

  // ── Address lookup ───────────────────────────────────────────────────────
  async function doAddressLookup() {
    const query = document.getElementById('address-input').value.trim();
    if (!query) return;

    const resultEl = document.getElementById('address-result');
    const btn = document.getElementById('address-search');
    btn.disabled = true;
    btn.textContent = 'Searching...';
    resultEl.className = 'mt-3 text-sm text-gray-500';
    resultEl.textContent = 'Looking up your address...';

    try {
      const url = 'https://nominatim.openstreetmap.org/search?'
        + new URLSearchParams({
          q: query.includes('New Zealand') || query.includes('NZ') ? query : query + ', New Zealand',
          format: 'json',
          limit: '3',
          countrycodes: 'nz',
          addressdetails: '1',
        });

      const resp = await fetch(url, { headers: { 'Accept': 'application/json' } });
      const results = await resp.json();

      if (!results.length) {
        resultEl.className = 'mt-3 text-sm text-orange-600 bg-orange-50 rounded-lg px-3 py-2';
        resultEl.textContent = "We couldn't find that address. Try adding your suburb, e.g. \"42 Queen St, Levin\".";
        return;
      }

      const { lat, lon } = results[0];
      const { area, distance } = findNearestArea(parseFloat(lat), parseFloat(lon));

      if (distance > 20) {
        resultEl.className = 'mt-3 text-sm text-orange-600 bg-orange-50 rounded-lg px-3 py-2';
        resultEl.textContent = "That address looks outside our service area. Call us on 06 368 8586 and we'll confirm.";
        return;
      }

      resultEl.className = 'mt-3 text-sm text-kiwi-700 bg-kiwi-50 rounded-lg px-3 py-2';
      resultEl.textContent = '';
      resultEl.innerHTML = `Your nearest collection zone is <strong>${area.name}</strong> &mdash; collected on <strong>${area.day}</strong> (${area.frequency}). Scroll down to see the map.`;
      showAreaResult(area);

    } catch {
      resultEl.className = 'mt-3 text-sm text-red-600 bg-red-50 rounded-lg px-3 py-2';
      resultEl.textContent = 'Address lookup is temporarily unavailable. Use the dropdown below or call us.';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Find';
    }
  }

  document.getElementById('address-search')?.addEventListener('click', doAddressLookup);
  document.getElementById('address-input')?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') doAddressLookup();
  });

  // ── Leaflet map ──────────────────────────────────────────────────────────
  function createMap() {
    const L = window.L;
    if (!L) return;

    const mapEl = document.getElementById('collection-map');
    if (!mapEl || mapEl._leaflet_id) return; // already initialised

    const map = L.map('collection-map', {
      center: [-40.640, 175.270],
      zoom: 11,
      zoomControl: true,
      scrollWheelZoom: false,
    });
    window._leafletMap = map;

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
      maxZoom: 18,
    }).addTo(map);

    const markers = {};
    areas.forEach((area) => {
      const circle = L.circleMarker([area.lat, area.lng], {
        radius: 14,
        fillColor: area.color,
        color: '#fff',
        weight: 3,
        opacity: 1,
        fillOpacity: 0.9,
      }).addTo(map);

      circle.bindPopup(`
        <div style="min-width:180px">
          <div style="font-weight:700;font-size:14px;margin-bottom:4px;color:#14532d">${area.name}</div>
          <div style="font-size:13px;color:#374151"><strong>Day:</strong> ${area.day}</div>
          <div style="font-size:13px;color:#374151;margin-top:2px"><strong>Frequency:</strong> ${area.frequency}</div>
          <div style="font-size:12px;color:#6b7280;margin-top:6px;line-height:1.4">${area.notes}</div>
        </div>
      `);

      markers[area.id] = circle;
    });
    window._leafletMarkers = markers;

    fetch(base + '/data/service-areas.geojson')
      .then((r) => r.json())
      .then((geojson) => {
        L.geoJSON(geojson, {
          filter: (f) => f.properties.id === 'service-boundary',
          style: (f) => ({
            color: f.properties.stroke || '#15803d',
            weight: f.properties['stroke-width'] || 2,
            opacity: f.properties['stroke-opacity'] || 0.7,
            fillColor: f.properties.fill || '#16a34a',
            fillOpacity: f.properties['fill-opacity'] || 0.07,
            dashArray: '6 4',
          }),
        }).addTo(map);
      })
      .catch(() => {});
  }

  function loadLeaflet() {
    if (window._leafletLoading) return;
    window._leafletLoading = true;

    if (window.L) { createMap(); return; }

    const script = document.createElement('script');
    script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
    script.crossOrigin = 'anonymous';
    script.onload = createMap;
    script.onerror = () => { window._leafletLoading = false; };
    document.head.appendChild(script);
  }

  // Mobile toggle
  const mapToggle = document.getElementById('map-toggle');
  const mapWrapper = document.getElementById('map-wrapper');
  mapToggle?.addEventListener('click', () => {
    const expanded = mapToggle.getAttribute('aria-expanded') === 'true';
    mapToggle.setAttribute('aria-expanded', String(!expanded));
    mapWrapper?.classList.toggle('hidden');
    mapToggle.textContent = expanded ? '🗺 View Service Area Map' : '✕ Hide Map';
    if (!expanded) loadLeaflet();
  });

  // Auto-init on desktop
  if (window.matchMedia('(min-width: 640px)').matches) {
    loadLeaflet();
  }
</script>
