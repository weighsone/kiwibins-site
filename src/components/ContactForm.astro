---
/**
 * ContactForm.astro
 * Posts to Web3Forms. Redirects to on-site success page.
 * Set PUBLIC_WEB3FORMS_KEY in your .env file.
 */
const w3fKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? '';
const successUrl = 'https://weighsone.github.io/kiwibins-site/success/contact/';
---

<form
  action="https://api.web3forms.com/submit"
  method="POST"
  class="space-y-5"
  novalidate
  aria-label="Contact form"
>
  <!-- Web3Forms required fields -->
  <input type="hidden" name="access_key" value={w3fKey} />
  <input type="hidden" name="subject" value="New contact message – Kiwibins Horowhenua" />
  <input type="hidden" name="from_name" value="Kiwibins Website" />
  <input type="hidden" name="redirect" value={successUrl} />

  <!-- Honeypot anti-spam -->
  <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" aria-hidden="true" />

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
    <div>
      <label for="contact-name" class="form-label">Full Name <span class="text-red-500" aria-hidden="true">*</span></label>
      <input
        type="text"
        id="contact-name"
        name="name"
        required
        autocomplete="name"
        class="form-input"
        placeholder="Your name"
      />
    </div>
    <div>
      <label for="contact-phone" class="form-label">Phone</label>
      <input
        type="tel"
        id="contact-phone"
        name="phone"
        autocomplete="tel"
        class="form-input"
        placeholder="021 123 4567"
      />
    </div>
  </div>

  <div>
    <label for="contact-email" class="form-label">Email <span class="text-red-500" aria-hidden="true">*</span></label>
    <input
      type="email"
      id="contact-email"
      name="email"
      required
      autocomplete="email"
      class="form-input"
      placeholder="you@example.com"
    />
  </div>

  <div>
    <label for="contact-address" class="form-label">Your Address <span class="text-gray-400 font-normal text-xs">(optional – helps us confirm your service area)</span></label>
    <input
      type="text"
      id="contact-address"
      name="address"
      autocomplete="street-address"
      class="form-input"
      placeholder="123 Main Street, Levin"
    />
  </div>

  <div>
    <label for="contact-message" class="form-label">Message <span class="text-red-500" aria-hidden="true">*</span></label>
    <textarea
      id="contact-message"
      name="message"
      required
      class="form-textarea"
      placeholder="How can we help? Let us know what you need..."
      rows="5"
    ></textarea>
  </div>

  <button type="submit" class="btn-primary w-full sm:w-auto">
    Send Message
    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5"/>
    </svg>
  </button>

  <p class="text-xs text-gray-400">
    We'll get back to you as soon as we can. For urgent matters call <a href="tel:063688586" class="text-kiwi-600 hover:underline">06 368 8586</a>.
  </p>
</form>
