---
import { u } from '../utils/url';

interface PricingRow {
  label: string;
  price: string;
  note?: string;
  highlight?: boolean;
}

interface Props {
  size: string;
  capacity: string;
  description: string;
  startingFrom?: string;
  pricing?: PricingRow[];
  orderHref?: string;
  contactHref?: string;
  notes?: string[];
  icon?: string;
  featured?: boolean;
}

const {
  size,
  capacity,
  description,
  startingFrom,
  pricing = [],
  orderHref,
  contactHref,
  notes = [],
  featured = false,
} = Astro.props;
---

<article
  class:list={[
    'rounded-xl border flex flex-col transition-shadow hover:shadow-md bg-white',
    featured
      ? 'border-kiwi-400 ring-2 ring-kiwi-400/30'
      : 'border-gray-200',
  ]}
  aria-label={`${size} bin option`}
>
  <!-- Card header -->
  <div class:list={['px-6 pt-6 pb-5 border-b border-gray-100']}>
    <div class="flex items-start justify-between gap-3">
      <div>
        <h3 class="text-xl font-bold text-kiwi-700">{size}</h3>
        <p class="text-sm mt-0.5 text-kiwi-600">{capacity}</p>
      </div>
      {startingFrom && (
        <div class="text-right shrink-0">
          <div class="text-2xl font-extrabold text-kiwi-700">{startingFrom}</div>
          <div class="text-xs text-gray-400">starting from</div>
        </div>
      )}
    </div>
    <p class="text-sm mt-3 leading-relaxed text-kiwi-600">{description}</p>
  </div>

  <!-- Pricing table -->
  {pricing.length > 0 && (
    <div class="px-6 py-4 flex-1">
      <p class="text-xs font-semibold uppercase tracking-wider mb-3 text-gray-400">
        Payment frequency
      </p>
      <div class="space-y-1">
        {pricing.map((row) => (
          <div
            class:list={[
              'flex items-center justify-between py-1.5 px-3 rounded-lg text-sm',
              row.highlight
                ? 'bg-kiwi-50 text-kiwi-700 font-semibold border border-kiwi-200'
                : 'text-kiwi-600',
            ]}
          >
            <span>{row.label}</span>
            <span class="flex items-center gap-2 font-semibold">
              {row.price}
              {row.note && (
                <span class="text-xs text-kiwi-500 font-bold">{row.note}</span>
              )}
            </span>
          </div>
        ))}
      </div>
    </div>
  )}

  <!-- Notes -->
  {notes.length > 0 && (
    <div class:list={['px-6 py-3', pricing.length > 0 ? 'border-t border-gray-100' : '']}>
      <ul class="space-y-1.5">
        {notes.map((note) => (
          <li class="flex items-start gap-2 text-xs text-kiwi-600">
            <svg class="w-3.5 h-3.5 shrink-0 mt-0.5 text-kiwi-500" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
            </svg>
            {note}
          </li>
        ))}
      </ul>
    </div>
  )}

  <!-- CTA -->
  <div class="px-6 pb-6 pt-4 border-t border-gray-100">
    {orderHref ? (
      <a href={orderHref} class="btn-primary w-full justify-center">
        Order Now
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
        </svg>
      </a>
    ) : contactHref ? (
      <a href={contactHref} class="btn-secondary w-full justify-center">
        Contact Us to Book
      </a>
    ) : null}
  </div>
</article>
