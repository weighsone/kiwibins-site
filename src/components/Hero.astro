---
import { u } from '../utils/url';

interface Props {
  headline: string;
  subheadline?: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  badge?: string;
  compact?: boolean;
  bgImage?: string;
}

const {
  headline,
  subheadline,
  primaryCta,
  secondaryCta,
  badge,
  compact = false,
  bgImage,
} = Astro.props;
---

<section
  class:list={[
    'relative text-white overflow-hidden',
    !bgImage && 'bg-kiwi-900',
    compact ? 'py-12 md:py-16' : 'py-24 md:py-36',
  ]}
  style={bgImage ? `background-image: url('${bgImage}'); background-size: cover; background-position: center;` : ''}
  aria-label="Page hero"
>
  <!-- Dark overlay for photo backgrounds -->
  {bgImage && (
    <div class="absolute inset-0 bg-black/55" aria-hidden="true"></div>
  )}

  <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    {badge && (
      <span class="inline-block bg-white/20 text-white text-xs font-semibold px-3 py-1 rounded-full mb-5 border border-white/30">
        {badge}
      </span>
    )}
    <h1 class:list={['font-extrabold leading-tight', compact ? 'text-3xl md:text-4xl' : 'text-4xl md:text-5xl lg:text-6xl']}>
      {headline}
    </h1>
    {subheadline && (
      <p class:list={['text-white/90 mt-4 leading-relaxed mx-auto', compact ? 'text-base md:text-lg max-w-2xl' : 'text-lg md:text-xl max-w-3xl']}>
        {subheadline}
      </p>
    )}
    {(primaryCta || secondaryCta) && (
      <div class="mt-8 flex flex-wrap gap-3 justify-center">
        {primaryCta && (
          <a href={primaryCta.href} class="btn-primary text-base px-8 py-3.5">
            {primaryCta.label}
          </a>
        )}
        {secondaryCta && (
          <a href={secondaryCta.href} class="inline-flex items-center gap-2 text-white font-bold px-6 py-3.5 rounded-lg border-2 border-white/40 hover:bg-white/10 transition-colors duration-150">
            {secondaryCta.label}
          </a>
        )}
      </div>
    )}
    <slot />
  </div>
</section>
