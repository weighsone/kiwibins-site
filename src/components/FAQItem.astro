---
interface Props {
  question: string;
  id: string;
  defaultOpen?: boolean;
}
const { question, id, defaultOpen = false } = Astro.props;
---

<div class="border border-gray-200 rounded-xl overflow-hidden" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
  <button
    id={`faq-btn-${id}`}
    type="button"
    class="w-full flex items-center justify-between gap-4 px-5 py-4 text-left bg-white hover:bg-kiwi-50 transition-colors duration-150 focus-visible:bg-kiwi-50"
    aria-expanded={String(defaultOpen)}
    aria-controls={`faq-panel-${id}`}
    itemprop="name"
  >
    <span class="font-semibold text-kiwi-900 text-sm md:text-base">{question}</span>
    <svg
      id={`faq-icon-${id}`}
      class:list={['w-5 h-5 text-kiwi-600 shrink-0 transition-transform duration-200', defaultOpen ? 'rotate-180' : '']}
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      viewBox="0 0 24 24"
      aria-hidden="true"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
    </svg>
  </button>
  <div
    id={`faq-panel-${id}`}
    role="region"
    aria-labelledby={`faq-btn-${id}`}
    class:list={[defaultOpen ? '' : 'hidden']}
    itemscope
    itemprop="acceptedAnswer"
    itemtype="https://schema.org/Answer"
  >
    <div class="px-5 pb-5 pt-1 text-sm text-gray-600 leading-relaxed border-t border-gray-100 bg-white" itemprop="text">
      <slot />
    </div>
  </div>
</div>

<script>
  // Progressively enhance all FAQ accordions on page
  document.querySelectorAll('[id^="faq-btn-"]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      const id = btn.id.replace('faq-btn-', '');
      const panel = document.getElementById(`faq-panel-${id}`);
      const icon = document.getElementById(`faq-icon-${id}`);

      btn.setAttribute('aria-expanded', String(!expanded));
      panel?.classList.toggle('hidden');
      icon?.classList.toggle('rotate-180');
    });
  });
</script>
