---
import Layout from '../components/Layout.astro';
import Hero from '../components/Hero.astro';
import { u } from '../utils/url';
---

<Layout
  title="Kiwibins Horowhenua"
  description="Levin's local bin company. Affordable weekly rubbish collection for homes and businesses across Horowhenua. Waitārere Beach to Manakau. Call 06 368 8586."
  canonicalPath="/"
>

  <Hero
    headline="Levin's local bin company handling rubbish collection across Horowhenua"
    primaryCta={{ label: 'get a kiwibin', href: u('/bins-and-prices/') }}
    secondaryCta={{ label: 'when and where', href: u('/when-and-where/') }}
    bgImage={u('/assets/images/hero-bg.jpg')}
  />

  <!-- About / service overview -->
  <section class="py-16 bg-white" aria-labelledby="about-heading">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 id="about-heading" class="text-3xl md:text-4xl font-extrabold text-kiwi-700 leading-tight mb-5">
        Weekly rubbish pickups from the Manawatu River Bridge, west to Waitārere Beach, east to Potts Road and down to Manakau
      </h2>
      <p class="text-kiwi-600 text-lg leading-relaxed max-w-2xl mx-auto">
        We've got a small team, big on service. With our owners in the business day to day, you know you will be well looked after.
      </p>
      <div class="mt-8">
        <a href={u('/about-us/')} class="btn-primary text-base px-8 py-3.5">more about us</a>
      </div>
    </div>
  </section>

  <!-- Bin sizes overview -->
  <section class="py-16 bg-[#ececec]" aria-labelledby="bins-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 id="bins-heading" class="text-3xl md:text-4xl font-extrabold text-kiwi-700 leading-tight">Kiwibin sizes</h2>
        <p class="text-kiwi-600 mt-3 text-lg">Get your kiwibins kerbside by 7am on collection day</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-5">
        {[
          { size: '44-Gallon Drum', from: '$23', per: 'per empty', desc: 'Text-based booking, pay per empty', href: u('/contact-us/') },
          { size: '120L Wheelie Bin', from: '$9', per: 'per week', desc: 'Good for 1 or 2 people', href: u('/order/120l/') },
          { size: '240L Wheelie Bin', from: '$13.20', per: 'per week', desc: 'Suits most households', href: u('/order/240l/') },
          { size: '660L Wheelie Bin', from: '$45', per: 'per week', desc: 'Commercial and multi-tenancy', href: u('/contact-us/') },
          { size: '1100L Wheelie Bin', from: '$70', per: 'per week', desc: 'High-volume commercial sites', href: u('/contact-us/') },
        ].map(({ size, from, per, desc, href }) => (
          <a
            href={href}
            class="flex flex-col rounded-xl border border-gray-200 bg-white p-5 transition-all duration-150 hover:border-kiwi-400 hover:shadow-md group"
            aria-label={`${size} – from ${from} ${per}. ${desc}`}
          >
            <div class="text-base font-bold text-kiwi-700">{size}</div>
            <div class="text-xs text-kiwi-600 mt-0.5">{desc}</div>
            <div class="mt-auto pt-3">
              <span class="text-xl font-extrabold text-kiwi-700">{from}</span>
              <span class="text-xs text-gray-400 ml-1">{per}</span>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-10 text-center">
        <a href={u('/bins-and-prices/')} class="btn-primary text-base px-8 py-3.5">
          see full pricing and order
        </a>
      </div>
    </div>
  </section>

  <!-- Service area -->
  <section class="py-16 bg-white" aria-labelledby="area-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8">
        <h2 id="area-heading" class="text-3xl md:text-4xl font-extrabold text-kiwi-700 leading-tight">Areas we service</h2>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div>
          <p class="text-kiwi-600 leading-relaxed text-lg">
            Weekly pickups from the Manawatu River Bridge, west to Waitārere Beach, east to Potts Road and south to Manakau. Most of Horowhenua is covered.
          </p>
          <ul class="mt-6 space-y-3 text-sm text-kiwi-600">
            {[
              { area: 'Levin (Purple Zone)', day: 'Tuesday' },
              { area: 'Levin (Orange Zone)', day: 'Wednesday' },
              { area: 'Levin (Green Zone)', day: 'Thursday' },
              { area: 'Ohau', day: 'Wednesday' },
              { area: 'Waitārere Beach', day: 'Monday' },
              { area: 'Manakau and Koputaroa', day: 'Alternate Wednesdays' },
            ].map(({ area, day }) => (
              <li class="flex items-center justify-between py-2 border-b border-gray-200 last:border-0">
                <span class="font-semibold">{area}</span>
                <span class="text-kiwi-700 font-bold text-xs bg-kiwi-50 px-2.5 py-1 rounded-full">{day}</span>
              </li>
            ))}
          </ul>
          <div class="mt-8">
            <a href={u('/when-and-where/')} class="btn-primary text-base px-8 py-3.5">areas we service</a>
          </div>
        </div>

        <!-- Service area map image -->
        <div>
          <img
            src={u('/assets/images/service-area-map.jpg')}
            alt="Map showing Kiwibins service areas across Horowhenua"
            class="rounded-xl shadow-md w-full border border-gray-200"
            loading="lazy"
            width="1200"
            height="682"
          />
          <p class="text-xs text-gray-400 mt-2 flex items-center gap-1">
            <svg class="w-3 h-3 shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
            </svg>
            Map boundaries are indicative. Contact us to confirm your collection day.
          </p>
        </div>
      </div>
    </div>
  </section>

</Layout>
