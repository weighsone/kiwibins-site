---
import Layout from '../components/Layout.astro';
import Hero from '../components/Hero.astro';
import { u } from '../utils/url';
---

<Layout
  title="Kiwibins Horowhenua"
  description="Levin's local bin company. Affordable weekly rubbish collection for homes and businesses across Horowhenua. Waitārere Beach to Manakau. Call 06 368 8586."
  canonicalPath="/"
>

  <Hero
    badge="Locally owned, Horowhenua"
    headline="Rubbish collection across Horowhenua"
    subheadline="Straightforward weekly wheelie bin service for homes and businesses. Waitārere Beach to Manakau. Call us on 06 368 8586."
    primaryCta={{ label: 'Get a Kiwibin', href: u('/bins-and-prices/') }}
    secondaryCta={{ label: 'Check your collection day', href: u('/when-and-where/') }}
    bgImage={u('/assets/images/hero-bg.jpg')}
  />

  <!-- Trust bar -->
  <section class="bg-kiwi-800 text-kiwi-100" aria-label="Key facts">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        {[
          { icon: '📞', label: 'Call us directly' },
          { icon: '🏡', label: 'Based in Manakau' },
          { icon: '⚡', label: 'Bin delivered in 3 days' },
          { icon: '💰', label: 'No lock-in contracts' },
        ].map(({ icon, label }) => (
          <div class="flex flex-col items-center gap-1.5">
            <span class="text-2xl" aria-hidden="true">{icon}</span>
            <span class="text-sm font-medium">{label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why local beats a chain -->
  <section class="py-16 bg-kiwi-50 border-b border-kiwi-100" aria-labelledby="local-heading">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div>
          <h2 id="local-heading" class="section-heading">Local business. Direct contact.</h2>
          <p class="text-gray-600 mt-4 leading-relaxed">
            Kiwibins is a small local business, owned and run right here in Horowhenua. When you ring about your bin, you're not waiting on hold to speak to a call centre in another city. You're talking to the person who owns the business and collects your rubbish.
          </p>
          <p class="text-gray-600 mt-3 leading-relaxed">
            Got a question? Problem with your service? Just call or text. It gets sorted quickly because there's no one else in the chain.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href="tel:063688586" class="btn-primary">Call 06 368 8586</a>
            <a href={u('/about-us/')} class="btn-secondary">About Kiwibins</a>
          </div>
        </div>
        <div class="grid grid-cols-1 gap-3">
          {[
            { them: 'Call centre hold music', us: 'Owner answers your call' },
            { them: 'Account portals and login screens', us: 'Call or text to get sorted' },
            { them: 'Weeks to set up', us: 'Bin at your door in 3 days' },
            { them: 'Rolling contracts', us: 'Pay weekly, monthly or yearly' },
          ].map(({ them, us }) => (
            <div class="bg-white rounded-xl border border-gray-200 overflow-hidden grid grid-cols-2 text-sm">
              <div class="px-4 py-3 text-gray-400 border-r border-gray-100 flex items-center gap-2">
                <svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
                {them}
              </div>
              <div class="px-4 py-3 text-kiwi-800 font-medium flex items-center gap-2">
                <svg class="w-3.5 h-3.5 text-kiwi-500 shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                {us}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Bin sizes overview -->
  <section class="py-20 bg-white" aria-labelledby="bins-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 id="bins-heading" class="section-heading">Pick the right bin size</h2>
        <p class="section-subheading mx-auto">From a 120L bin for one person to a 1100L container for commercial sites. Pricing is straightforward with no hidden fees.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-5">
        {[
          { size: '44-Gallon Drum', from: '$23', per: 'per empty', desc: 'Text-based booking, pay per empty', href: u('/contact-us/') },
          { size: '120L Wheelie Bin', from: '$9', per: 'per week', desc: 'Good for 1 or 2 people', href: u('/order/120l/'), featured: true },
          { size: '240L Wheelie Bin', from: '$13.20', per: 'per week', desc: 'Suits most households', href: u('/order/240l/'), featured: true },
          { size: '660L Wheelie Bin', from: '$45', per: 'per week', desc: 'Commercial and multi-tenancy', href: u('/contact-us/') },
          { size: '1100L Wheelie Bin', from: '$70', per: 'per week', desc: 'High-volume commercial sites', href: u('/contact-us/') },
        ].map(({ size, from, per, desc, href, featured }) => (
          <a
            href={href}
            class:list={[
              'flex flex-col rounded-2xl border p-5 transition-all duration-150 group',
              featured
                ? 'bg-kiwi-50 border-kiwi-300 hover:border-kiwi-500 hover:shadow-md'
                : 'bg-white border-gray-200 hover:border-kiwi-300 hover:shadow-sm',
            ]}
            aria-label={`${size} – from ${from} ${per}. ${desc}`}
          >
            <div class="w-10 h-10 rounded-xl bg-kiwi-100 flex items-center justify-center mb-3 group-hover:bg-kiwi-200 transition-colors" aria-hidden="true">
              <svg class="w-5 h-5 text-kiwi-700" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/>
              </svg>
            </div>
            <div class="text-base font-bold text-kiwi-900">{size}</div>
            <div class="text-xs text-gray-500 mt-0.5">{desc}</div>
            <div class="mt-auto pt-3">
              <span class="text-xl font-extrabold text-kiwi-700">{from}</span>
              <span class="text-xs text-gray-400 ml-1">{per}</span>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-10 text-center">
        <a href={u('/bins-and-prices/')} class="btn-primary">
          See full pricing and order
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Service area + map image -->
  <section class="py-20 bg-gray-50" aria-labelledby="area-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div>
          <h2 id="area-heading" class="section-heading">Where we collect</h2>
          <p class="text-gray-600 mt-4 leading-relaxed">
            Weekly pickups from the Manawatu River Bridge, west to Waitārere Beach, east to Potts Road and south to Manakau. Most of Horowhenua is covered.
          </p>
          <ul class="mt-6 space-y-3 text-sm text-gray-700">
            {[
              { area: 'Levin (Purple Zone)', day: 'Tuesday' },
              { area: 'Levin (Orange Zone)', day: 'Wednesday' },
              { area: 'Levin (Green Zone)', day: 'Thursday' },
              { area: 'Ohau', day: 'Wednesday' },
              { area: 'Waitārere Beach', day: 'Monday' },
              { area: 'Manakau and Koputaroa', day: 'Alternate Wednesdays' },
            ].map(({ area, day }) => (
              <li class="flex items-center justify-between py-2 border-b border-gray-200 last:border-0">
                <span class="font-medium">{area}</span>
                <span class="text-kiwi-700 font-semibold text-xs bg-kiwi-100 px-2.5 py-1 rounded-full">{day}</span>
              </li>
            ))}
          </ul>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href={u('/when-and-where/')} class="btn-primary">
              View interactive map
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z"/>
              </svg>
            </a>
            <a href={u('/contact-us/')} class="btn-secondary">Not sure? Ask us</a>
          </div>
        </div>

        <!-- Service area map image -->
        <div>
          <img
            src={u('/assets/images/service-area-map.jpg')}
            alt="Map showing Kiwibins service areas across Horowhenua"
            class="rounded-2xl shadow-md w-full border border-gray-200"
            loading="lazy"
            width="1200"
            height="682"
          />
          <p class="text-xs text-gray-400 mt-2 flex items-center gap-1">
            <svg class="w-3 h-3 shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
            </svg>
            Map boundaries are indicative. Contact us to confirm your collection day.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA strip -->
  <section class="bg-gradient-to-r from-kiwi-800 to-kiwi-700 py-16" aria-label="Call to action">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-extrabold text-white mb-3">Ready to get started?</h2>
      <p class="text-kiwi-200 mb-8">Pick your bin size and fill in the form. We'll have a kiwibin at your kerb within 3 working days.</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={u('/bins-and-prices/')} class="btn-orange">
          See bins and prices
        </a>
        <a href={u('/contact-us/')} class="inline-flex items-center gap-2 text-white font-semibold px-6 py-3 rounded-lg border-2 border-white/30 hover:bg-white/10 transition-colors">
          Get in touch
        </a>
      </div>
    </div>
  </section>

</Layout>
