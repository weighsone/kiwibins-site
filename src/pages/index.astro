---
import Layout from '../components/Layout.astro';
import Hero from '../components/Hero.astro';
import { u } from '../utils/url';
---

<Layout
  title="Kiwibins Horowhenua"
  description="Levin's local bin company. Affordable weekly rubbish collection for homes and businesses across Horowhenua – from Waitārere Beach to Manakau."
  canonicalPath="/"
>

  <!-- Hero -->
  <Hero
    badge="Levin-born & locally owned"
    headline="Horowhenua's Local Bin Company"
    subheadline="Big on service, small on fuss. Weekly rubbish collection for homes and businesses across Horowhenua — from Waitārere Beach to Manakau."
    primaryCta={{ label: 'Get a Kiwibin', href: u('/bins-and-prices/') }}
    secondaryCta={{ label: 'Check your collection day', href: u('/when-and-where/') }}
  />

  <!-- Trust bar -->
  <section class="bg-kiwi-800 text-kiwi-100" aria-label="Key facts">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        {[
          { icon: '🏡', label: 'Locally owned & family-run' },
          { icon: '📞', label: 'Deal directly with the owners' },
          { icon: '♻️', label: 'Serving Horowhenua since 2020' },
          { icon: '⚡', label: 'Bin delivered within 3 days' },
        ].map(({ icon, label }) => (
          <div class="flex flex-col items-center gap-1.5">
            <span class="text-2xl" aria-hidden="true">{icon}</span>
            <span class="text-sm font-medium">{label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Bin sizes overview -->
  <section class="py-20 bg-white" aria-labelledby="bins-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 id="bins-heading" class="section-heading">Choose your kiwibin size</h2>
        <p class="section-subheading mx-auto">From compact 120L bins for small households to 1100L commercial containers. We've got a size to suit every property.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-5">
        {[
          { size: '44-Gallon Drum', from: '$23', per: 'per empty', desc: 'Old-school drum service, text to book', href: u('/contact-us/') },
          { size: '120L Wheelie Bin', from: '$9', per: 'per week', desc: 'Ideal for 1–2 person households', href: u('/order/120l/'), featured: true },
          { size: '240L Wheelie Bin', from: '$13.20', per: 'per week', desc: 'Perfect for families of 3+', href: u('/order/240l/'), featured: true },
          { size: '660L Wheelie Bin', from: '$45', per: 'per week', desc: 'Commercial & multi-tenancy', href: u('/contact-us/') },
          { size: '1100L Wheelie Bin', from: '$70', per: 'per week', desc: 'Large commercial properties', href: u('/contact-us/') },
        ].map(({ size, from, per, desc, href, featured }) => (
          <a
            href={href}
            class:list={[
              'flex flex-col rounded-2xl border p-5 transition-all duration-150 group',
              featured
                ? 'bg-kiwi-50 border-kiwi-300 hover:border-kiwi-500 hover:shadow-md'
                : 'bg-white border-gray-200 hover:border-kiwi-300 hover:shadow-sm',
            ]}
            aria-label={`${size} – from ${from} ${per}. ${desc}`}
          >
            <div class="w-10 h-10 rounded-xl bg-kiwi-100 flex items-center justify-center mb-3 group-hover:bg-kiwi-200 transition-colors" aria-hidden="true">
              <svg class="w-5 h-5 text-kiwi-700" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/>
              </svg>
            </div>
            <div class="text-base font-bold text-kiwi-900">{size}</div>
            <div class="text-xs text-gray-500 mt-0.5">{desc}</div>
            <div class="mt-auto pt-3">
              <span class="text-xl font-extrabold text-kiwi-700">{from}</span>
              <span class="text-xs text-gray-400 ml-1">{per}</span>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-10 text-center">
        <a href={u('/bins-and-prices/')} class="btn-primary">
          See full pricing &amp; order
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Service area + schedule teaser -->
  <section class="py-20 bg-kiwi-50" aria-labelledby="area-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 id="area-heading" class="section-heading">We service your area</h2>
          <p class="text-gray-600 mt-4 leading-relaxed">
            Weekly rubbish pickups from the Manawatu River Bridge, west to Waitārere Beach, east to Potts Road and south to Manakau. That's most of Horowhenua covered.
          </p>
          <ul class="mt-6 space-y-3 text-sm text-gray-700">
            {[
              { area: 'Levin (Purple Zone)', day: 'Tuesday' },
              { area: 'Levin (Orange Zone)', day: 'Wednesday' },
              { area: 'Levin (Green Zone)', day: 'Thursday' },
              { area: 'Ohau', day: 'Wednesday' },
              { area: 'Waitārere Beach', day: 'Monday' },
              { area: 'Manakau & Koputaroa', day: 'Alternate Wednesdays' },
            ].map(({ area, day }) => (
              <li class="flex items-center justify-between py-2 border-b border-kiwi-100 last:border-0">
                <span class="font-medium">{area}</span>
                <span class="text-kiwi-700 font-semibold text-xs bg-kiwi-100 px-2.5 py-1 rounded-full">{day}</span>
              </li>
            ))}
          </ul>
          <div class="mt-6">
            <a href={u('/when-and-where/')} class="btn-primary">
              View interactive map
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- Collection reminder card -->
        <div class="card border-kiwi-200 bg-white">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 bg-orange-100 rounded-xl flex items-center justify-center" aria-hidden="true">
              <svg class="w-5 h-5 text-orange-600" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
              </svg>
            </div>
            <h3 class="font-bold text-kiwi-900">Bin out by 7am</h3>
          </div>
          <p class="text-gray-600 text-sm leading-relaxed">
            Get your kiwibin kerbside, facing the street, by <strong>7am on your collection day</strong>. Our truck comes through early — don't miss it!
          </p>
          <div class="mt-5 space-y-2.5 text-sm">
            {[
              'Lid must be fully shut',
              'Maximum weight limits apply (120L = 15kg, 240L = 30kg)',
              'No hazardous waste, hot ashes, or liquids',
              'Extra bags will be left for next week',
            ].map((tip) => (
              <div class="flex items-start gap-2 text-gray-600">
                <svg class="w-4 h-4 text-kiwi-500 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                {tip}
              </div>
            ))}
          </div>
          <a href={u('/faq/')} class="mt-5 inline-flex items-center gap-1 text-sm text-kiwi-600 hover:text-kiwi-800 font-medium transition-colors">
            Read the full FAQ
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Kiwibins -->
  <section class="py-20 bg-white" aria-labelledby="why-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 id="why-heading" class="section-heading">Why choose Kiwibins?</h2>
        <p class="section-subheading mx-auto">No call centres. No runaround. Just a hardworking local team that knows your street.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          {
            icon: '👋',
            title: 'Deal with the owners',
            body: 'Adam and Judith are hands-on in the business every day. When you call, you\'re talking to the people who actually run the trucks — not a call centre.',
          },
          {
            icon: '🏘️',
            title: 'Born and bred local',
            body: 'Adam is a Levin boy through and through. We took over from Levin Mini Bins in 2020 and we\'re committed to serving our community for the long haul.',
          },
          {
            icon: '💰',
            title: 'Flexible payment options',
            body: 'Pay weekly, fortnightly, monthly, or save up to 15% by paying yearly. We make it easy to manage your waste costs your way.',
          },
          {
            icon: '📦',
            title: 'Fast setup',
            body: 'We aim to drop your kiwibin off within 3 working days of signing up. Get sorted quickly and never worry about rubbish day again.',
          },
          {
            icon: '🔧',
            title: 'Old-school drum service',
            body: 'Still running a 44-gallon drum? Our man Eric has 25+ years of experience and runs the drum emptying service on a simple text-booking system.',
          },
          {
            icon: '📈',
            title: 'Growing service areas',
            body: 'Manakau and Koputaroa are currently fortnightly — as more customers come on board we\'ll upgrade to weekly. Community-driven growth.',
          },
        ].map(({ icon, title, body }) => (
          <div class="flex gap-4">
            <div class="text-3xl shrink-0" aria-hidden="true">{icon}</div>
            <div>
              <h3 class="font-bold text-kiwi-900 mb-1.5">{title}</h3>
              <p class="text-sm text-gray-600 leading-relaxed">{body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA strip -->
  <section class="bg-gradient-to-r from-kiwi-800 to-kiwi-700 py-16" aria-label="Call to action">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-extrabold text-white mb-3">Ready to get started?</h2>
      <p class="text-kiwi-200 mb-8">Pick your bin size, choose your payment plan, and we'll have a kiwibin at your kerb within 3 days.</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={u('/bins-and-prices/')} class="btn-orange">
          See bins &amp; prices
        </a>
        <a href={u('/contact-us/')} class="inline-flex items-center gap-2 text-white font-semibold px-6 py-3 rounded-lg border-2 border-white/30 hover:bg-white/10 transition-colors">
          Get in touch
        </a>
      </div>
    </div>
  </section>

</Layout>
