---
import Layout from '../components/Layout.astro';
import Hero from '../components/Hero.astro';
import CollectionMap from '../components/CollectionMap.astro';
import { u } from '../utils/url';
---

<Layout
  title="When & Where – Collection Schedule"
  description="Find your bin collection day in Horowhenua. Levin, Ohau, Waitārere Beach, Manakau, and Koputaroa collection schedule. Interactive map included."
  canonicalPath="/when-and-where/"
>

  <Hero
    headline="When &amp; Where"
    subheadline="Find your collection day and service area. Use the dropdown to look up your suburb, or browse the schedule table below."
    compact
  >
    <!-- Quick badge reminder -->
    <div class="mt-6 inline-flex items-center gap-2 bg-white/20 text-white border border-white/30 rounded-full px-4 py-2 text-sm font-medium">
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
      </svg>
      Have your bin kerbside by <strong class="ml-0.5">7am</strong> on collection day
    </div>
  </Hero>

  <!-- Service area description -->
  <section class="bg-[#ececec] border-b border-gray-200" aria-label="Service area overview">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
        <div class="w-10 h-10 bg-kiwi-700 rounded-xl flex items-center justify-center text-white shrink-0" aria-hidden="true">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
          </svg>
        </div>
        <div>
          <p class="font-semibold text-kiwi-700">Service area</p>
          <p class="text-kiwi-600 text-sm mt-0.5">
            Weekly rubbish pickups from the <strong>Manawatu River Bridge</strong>, west to <strong>Waitārere Beach</strong>, east to <strong>Potts Road</strong> and south to <strong>Manakau</strong>.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Interactive map section -->
  <section class="py-14 bg-white" aria-labelledby="map-heading">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 id="map-heading" class="text-2xl font-extrabold text-kiwi-700 mb-2">Find your collection day</h2>
      <p class="text-gray-500 text-sm mb-8">Select your suburb from the dropdown to see your collection day, or browse the full schedule in the table below.</p>

      <CollectionMap />
    </div>
  </section>

  <!-- Important notes -->
  <section class="py-12 bg-[#ececec]" aria-labelledby="notes-heading">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 id="notes-heading" class="text-xl font-bold text-kiwi-700 mb-6">Important collection notes</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {[
          {
            icon: '🕖',
            title: 'Out by 7am',
            body: 'Your kiwibin must be kerbside, facing the street, by 7am on collection day. Our trucks start early.',
          },
          {
            icon: '🚫',
            title: 'Lid must shut',
            body: 'If your bin lid cannot shut, extra bags will be left and collected the following week. Don\'t overfill.',
          },
          {
            icon: '⚖️',
            title: 'Weight limits',
            body: '120L bins: max 15 kg. 240L bins: max 30 kg. Overweight bins may not be collected.',
          },
          {
            icon: '📅',
            title: 'Public holidays',
            body: 'Collection days may shift over public holidays. Check our Facebook page @kiwibins for holiday schedule updates.',
          },
          {
            icon: '🔄',
            title: 'Manakau & Koputaroa',
            body: 'These areas are currently fortnightly (alternate Wednesdays). Contact us to confirm your next collection date.',
          },
          {
            icon: '❓',
            title: 'Not sure of your zone?',
            body: 'Unsure which Levin zone you\'re in? Call us on 06 368 8586 or send a message and we\'ll look it up for you.',
          },
        ].map(({ icon, title, body }) => (
          <div class="card flex items-start gap-4 p-5">
            <span class="text-2xl shrink-0" aria-hidden="true">{icon}</span>
            <div>
              <h3 class="font-bold text-kiwi-700 text-sm mb-1">{title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 bg-kiwi-900" aria-label="Still not sure">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-xl font-bold text-white mb-2">Still not sure about your day?</h2>
      <p class="text-gray-300 text-sm mb-6">Get in touch and we'll look it up for you.</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="tel:063688586" class="btn-primary">Call 06 368 8586</a>
        <a href={u('/contact-us/')} class="inline-flex items-center gap-2 text-white font-semibold px-5 py-2.5 rounded-lg border-2 border-white/30 hover:bg-white/10 transition-colors text-sm">
          Send a message
        </a>
      </div>
    </div>
  </section>

</Layout>
