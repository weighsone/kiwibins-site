---
import Layout from '../components/Layout.astro';
import Hero from '../components/Hero.astro';
import { u } from '../utils/url';
---

<Layout
  title="About Us"
  description="Kiwibins Horowhenua is run by Maggie Bruce, based in Manakau. A small local rubbish collection business serving Levin and the wider Horowhenua region."
  canonicalPath="/about-us/"
>

  <Hero
    headline="About Kiwibins Horowhenua"
    subheadline="A small team you can actually call."
    compact
  />

  <section class="py-16 bg-white" aria-labelledby="story-heading">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 id="story-heading" class="section-heading">Horowhenua through and through</h2>
          <div class="mt-5 space-y-4 text-gray-600 leading-relaxed">
            <p>
              Kiwibins Horowhenua is owned and run by <strong class="text-kiwi-900">Maggie Bruce</strong>, based out on South Manakau Road in Manakau. That's right in the middle of the area we service, so Maggie knows these roads, these properties, and these communities first-hand.
            </p>
            <p>
              We're a small operation, and that's deliberate. When you ring us, you get Maggie. When you have a problem, Maggie sorts it. No ticket systems, no call centres, no waiting for someone to check your file.
            </p>
            <p>
              We run weekly wheelie bin collection across Horowhenua and a text-based drum emptying service for customers who prefer it. Simple, reliable, local.
            </p>
          </div>
        </div>

        <div class="space-y-4">
          {[
            {
              icon: '📞',
              title: 'Call and Maggie answers',
              body: 'No hold music. No call centre. You deal directly with the owner every time.',
            },
            {
              icon: '🗺️',
              title: 'Based in the area she services',
              body: 'Maggie lives on South Manakau Road. She knows the roads, the properties, and the people she collects from.',
            },
            {
              icon: '⚡',
              title: 'Fast to set up',
              body: 'We aim to get your bin to you within 3 working days of signing up. No long waits or online portals to navigate.',
            },
            {
              icon: '💬',
              title: 'Flexible to deal with',
              body: 'Pay weekly, fortnightly, monthly or yearly. Need to pause? Change your service? Just call or text.',
            },
          ].map(({ icon, title, body }) => (
            <div class="flex items-start gap-4 p-4 rounded-xl bg-kiwi-50 border border-kiwi-100">
              <span class="text-2xl shrink-0" aria-hidden="true">{icon}</span>
              <div>
                <h3 class="font-bold text-kiwi-900 text-sm mb-0.5">{title}</h3>
                <p class="text-sm text-gray-600">{body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-14 bg-kiwi-50 border-y border-kiwi-100" aria-labelledby="drum-heading">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="card max-w-2xl mx-auto text-center">
        <div class="w-16 h-16 bg-kiwi-100 rounded-2xl flex items-center justify-center mx-auto mb-4 text-3xl" aria-hidden="true">
          🚛
        </div>
        <h2 id="drum-heading" class="text-xl font-bold text-kiwi-900 mb-3">44-gallon drum service</h2>
        <p class="text-gray-600 text-sm leading-relaxed">
          Prefer a drum over a wheelie bin? We still run a text-based drum emptying service for customers who want it. Just text <a href="sms:0212033205" class="text-kiwi-600 hover:underline font-semibold">021 203 3205</a> to book an empty. $23 per empty, cash on the day or by bank transfer.
        </p>
      </div>
    </div>
  </section>

  <section class="py-14 bg-white" aria-labelledby="service-area-heading">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 id="service-area-heading" class="section-heading mb-4">Our service area</h2>
      <p class="text-gray-600 max-w-2xl mx-auto">
        We collect across Horowhenua from the Manawatu River Bridge, west to Waitārere Beach, east to Potts Road and south to Manakau. That covers Levin, Ohau, Waitārere Beach, Manakau, and Koputaroa.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={u('/when-and-where/')} class="btn-primary">
          View collection schedule
        </a>
        <a href={u('/contact-us/')} class="btn-secondary">
          Get in touch
        </a>
      </div>
    </div>
  </section>

  <section class="py-14 bg-kiwi-900 text-white" aria-labelledby="contact-details-heading">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 id="contact-details-heading" class="text-2xl font-extrabold text-white text-center mb-10">Get in touch</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">
        {[
          { label: 'Phone', value: '06 368 8586', href: 'tel:063688586', icon: '📞' },
          { label: 'Text (drums)', value: '021 203 3205', href: 'sms:0212033205', icon: '💬' },
          { label: 'Email', value: 'info@kiwibinshorowhenua.co.nz', href: 'mailto:info@kiwibinshorowhenua.co.nz', icon: '✉️' },
          { label: 'Based in', value: 'Manakau, Horowhenua', href: undefined, icon: '📍' },
        ].map(({ label, value, href, icon }) => (
          <div class="text-center">
            <div class="text-3xl mb-2" aria-hidden="true">{icon}</div>
            <div class="text-xs font-semibold text-kiwi-400 uppercase tracking-wider mb-1">{label}</div>
            {href ? (
              <a href={href} class="text-kiwi-100 hover:text-white text-sm font-medium transition-colors break-all">
                {value}
              </a>
            ) : (
              <span class="text-kiwi-100 text-sm">{value}</span>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>
